# Copiez ce fichier vers .env puis renseignez les valeurs.

# Local SQLite : DATABASE_URL="file:./prisma/dev.db"
# Neon / Postgres : DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"
DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"
AUTH_SECRET="changez-moi-minimum-32-caracteres-en-production"
AUTH_URL="http://localhost:3000"
# URL publique de l’app (succès / annulation Stripe). En prod : https://votredomaine.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Déploiement Vercel ---
# Projet Git : définir « Root Directory » = web (Import GitHub → Settings → General).
# Variables à copier depuis ce fichier dans Vercel → Settings → Environment Variables.
# DATABASE_URL : PostgreSQL (Neon, Supabase, etc.) — pas de fichier SQLite file:./... en prod.
# AUTH_URL et NEXT_PUBLIC_APP_URL : https://votre-app.vercel.app (ou votre domaine).
# Après la première mise en prod : exécuter prisma migrate deploy avec DATABASE_URL Postgres.

# PAYMENT_PROVIDER=stripe

# Paddle Billing — inscription élève (alternative à Stripe)
# PADDLE_API_KEY=
# Secret notifications (signature webhook)
# PADDLE_WEBHOOK_SECRET_KEY=
# sandbox | production — défaut sandbox si absent
# PADDLE_ENVIRONMENT=sandbox
# Prix catalogue Paddle (`pri_…`) recommandé ; sinon prix hors catalogue :
# PADDLE_PRICE_ID_ELEVE_INSCRIPTION=
# Montant en plus petite unité (comme Stripe : 9900 = 99,00)
# PADDLE_ELEVE_INSCRIPTION_AMOUNT=9900
# Si prix hors catalogue uniquement — devise SDK (liste Paddle ; sinon créez un Price dans le dashboard)
# PADDLE_CHECKOUT_CURRENCY=EUR
# URL webhook à déclarer dans Paddle : https://votredomaine.com/api/webhooks/paddle

# Stripe — inscription élève (Checkout)
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
# Webhook : checkout.session.completed — https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=
# Soit un Price ID (recommandé en prod), soit montant ci‑dessous
STRIPE_PRICE_ID_ELEVE_INSCRIPTION=
# Montant en centimes MAD si pas de Price ID (9900 = 99,00 MAD)
STRIPE_ELEVE_INSCRIPTION_AMOUNT=9900

# Uniquement en NODE_ENV=development : inscription élève sans Stripe (ne pas utiliser en prod)
# Jamais true en production — sinon inscription élève sans carte / sans Paddle.
STRIPE_BYPASS_IN_DEV=false

# CMI (Maroc) — Methodix 2.0 ; remplace / complète Stripe selon contrat marchand
# @see src/config/methodix-plans.v2.ts
# CMI_WEBHOOK_SECRET=
# URL publique du webhook (pour tableau de bord CMI)
# CMI_WEBHOOK_PUBLIC_URL=https://methodix.ma/api/webhooks/cmi
# CMI_SUCCESS_URL=https://methodix.ma/fr/apres-connexion?payment=success
# CMI_CANCEL_URL=https://methodix.ma/fr/inscription?payment=cancelled

# Aide maths (fichier élève) — recommandé : clé OpenAI
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Aide IA devoirs (toutes matières) — OpenAI ou Ollama
# MATHS_AI_PROVIDER=ollama
# OLLAMA_HOST=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2
